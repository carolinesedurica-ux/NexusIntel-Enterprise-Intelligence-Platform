# ─── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Bright Data ──────────────────────────────────────────────
# brightdata.com → My Account → Account Settings → API Tokens
BRIGHTDATA_API_KEY=your_brightdata_api_key_here
BRIGHTDATA_CUSTOMER_ID=your_customer_id_here

# Web Unlocker zone (also used for SERP)
# brightdata.com → Proxies & Scraping → Zones → Web Unlocker
BRIGHTDATA_UNLOCKER_ZONE=unlocker
BRIGHTDATA_UNLOCKER_PASSWORD=your_zone_password_here

# Scraping Browser zone (Playwright remote browser)
# brightdata.com → Proxies & Scraping → Zones → Scraping Browser
BRIGHTDATA_SCRAPING_BROWSER_ZONE=scraping_browser
BRIGHTDATA_SCRAPING_BROWSER_PASSWORD=your_sb_password_here

# ─── Server ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001
ENV=development
LOG_LEVEL=INFO

# ─── Alerts ───────────────────────────────────────────────────
# Comma-separated webhook URLs to POST intelligence reports to
ALERT_WEBHOOK_URLS=
